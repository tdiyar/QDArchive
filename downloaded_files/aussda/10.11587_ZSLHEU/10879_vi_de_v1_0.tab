"VAR22"	",00"	"nicht genannt"
"VAR22"	"1,00"	"genannt"
"VAR23"	"Variable Label"	"Würden Sie sich mehr Informationen von der Diözese Eisenstadt wünschen?"
"VAR23"	"1,00"	"ja"
"VAR23"	"2,00"	"nein"
"VAR23"	"3,00"	"keine Angabe"
