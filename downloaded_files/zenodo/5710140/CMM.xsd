                        <xs:appinfo source="CMMxpath"
                            >/CMM/QuestionsResponses/Questions/QuestionItem/UserIDforQuestionItem/@TypeofUserIDforQuestionItem</xs:appinfo>
                        <xs:appinfo source="ddi32xpath"
                            >/ddi:DDIInstance/g:ResourcePackage/dc:QuestionScheme/dc:QuestionItem/r:UserID/@typeOfUserID</xs:appinfo>
                    </xs:annotation>
                </xs:attribute>
            </xs:extension>
        </xs:simpleContent>
    </xs:complexType>
