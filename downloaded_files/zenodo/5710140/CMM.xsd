<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns="cessda:CMM"
    xmlns:xhtml="http://www.w3.org/1999/xhtml" targetNamespace="cessda:CMM"
    elementFormDefault="qualified">
    <!-- Following import only needed if importing XHTML namespace for e.g. "Abstract" element - see end of of file also.-->
    <!-- <xs:import namespace="http://www.w3.org/1999/xhtml" schemaLocation="http://www.w3.org/2002/08/xhtml/xhtml1-strict.xsd"/>-->
    <xs:import namespace="http://www.w3.org/XML/1998/namespace"
        schemaLocation="http://www.w3.org/2001/03/xml.xsd"/>
    <!--*****************************************************************-->
    <!--ROOT  -->
    <xs:element id="CMM_00.00.00.00.00.00" name="CMM" type="CMMType">
        <xs:annotation>
            <xs:documentation xml:lang="en">Root level element for CESSDA Metadata Model XML
                Document</xs:documentation>
            <xs:appinfo source="CMMxpath">/CMM</xs:appinfo>
            <xs:appinfo source="ddi32xpath">null</xs:appinfo>
        </xs:annotation>
    </xs:element>
    <xs:complexType name="CMMType">
        <xs:sequence>
            <xs:element id="CMM_01.00.00.00.00.00" name="Study" type="StudyType">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Information on the
                        study/studies</xs:documentation>
                    <xs:appinfo source="CMMxpath">/CMM/Study</xs:appinfo>
                    <xs:appinfo source="ddi32xpath">null</xs:appinfo>
                    <xs:appinfo source="usage">MANDATORY</xs:appinfo>
                </xs:annotation>
            </xs:element>
            <xs:element id="CMM_02.00.00.00.00.00" name="Person" type="PersonType" minOccurs="0"
                maxOccurs="unbounded">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Information on individual(s)</xs:documentation>
                    <xs:appinfo source="CMMxpath">/CMM/Person</xs:appinfo>
                    <xs:appinfo source="ddi32xpath">null</xs:appinfo>
                </xs:annotation>
            </xs:element>
            <xs:element id="CMM_03.00.00.00.00.00" name="OrganizationConsortium"
                type="OrganizationConsortiumType" minOccurs="0" maxOccurs="unbounded">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Organisation/Consortium
                        Information</xs:documentation>
                    <xs:appinfo source="CMMxpath">/CMM/OrganizationConsortium</xs:appinfo>
                    <xs:appinfo source="ddi32xpath">null</xs:appinfo>
                    <xs:appinfo source="usage">RECOMMENDED</xs:appinfo>
                </xs:annotation>
            </xs:element>
            <xs:element id="CMM_04.00.00.00.00.00" name="Dataset" type="DatasetType" minOccurs="0"
                maxOccurs="unbounded">
                <xs:annotation>
                    <xs:documentation xml:lang="en">A collection of data, where every column of the
                        statistical data matrix represents a particular variable, and each row
                        corresponds to a given member of the data set in
                        question.</xs:documentation>
                    <xs:appinfo source="CMMxpath">/CMM/Dataset</xs:appinfo>
                    <xs:appinfo source="ddi32xpath">null</xs:appinfo>
                    <xs:appinfo source="usage">RECOMMENDED</xs:appinfo>
                </xs:annotation>
            </xs:element>
            <xs:element id="CMM_05.00.00.00.00.00" name="Instrument" type="InstrumentType"
                minOccurs="0" maxOccurs="unbounded">
                <xs:annotation>
                    <xs:documentation xml:lang="en"> A tool to obtain data from respondents. For
                        most social and behavioral surveys, the instrument involves a questionnaire
                        with questions and response options.</xs:documentation>
                    <xs:appinfo source="CMMxpath">/CMM/Instrument</xs:appinfo>
                    <xs:appinfo source="ddi32xpath">null</xs:appinfo>
                    <xs:appinfo source="usage">RECOMMENDED</xs:appinfo>
                </xs:annotation>
            </xs:element>
            <xs:element id="CMM_06.00.00.00.00.00" name="QuestionsResponses"
                type="QuestionsResponsesType" minOccurs="0" maxOccurs="1">
                <xs:annotation>
                    <xs:appinfo source="CMMxpath">/CMM/QuestionsResponses</xs:appinfo>
                    <xs:appinfo source="ddi32xpath">null</xs:appinfo>
                    <xs:appinfo source="usage">RECOMMENDED</xs:appinfo>
                </xs:annotation>
            </xs:element>
            <xs:element id="CMM_07.00.00.00.00.00" name="Concept" type="ConceptType" minOccurs="0"
                maxOccurs="unbounded">
                <xs:annotation>
                    <xs:appinfo source="CMMxpath">/CMM/Concept</xs:appinfo>
                    <xs:appinfo source="ddi32xpath">null</xs:appinfo>
                    <xs:documentation xml:lang="en">Concept(s) of the Question.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element id="CMM_08.00.00.00.00.00" name="Document" type="DocumentType" minOccurs="0"
                maxOccurs="unbounded">
                <xs:annotation>
                    <xs:appinfo source="CMMxpath">/CMM/Document</xs:appinfo>
                    <xs:appinfo source="ddi32xpath">null</xs:appinfo>
                    <xs:documentation xml:lang="en">All documents that a SP might want to add in
                        addition (e.g. Codebook).</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element id="CMM_09.00.00.00.00.00" name="Publication" type="PublicationType"
                minOccurs="0" maxOccurs="unbounded">
                <xs:annotation>
                    <xs:appinfo source="CMMxpath">/CMM/Publication</xs:appinfo>
                    <xs:appinfo source="ddi32xpath">null</xs:appinfo>
                    <xs:documentation xml:lang="en">Information on publication(s) that is/are
                        related to the resource if not entered at Related ID.</xs:documentation>
                    <xs:appinfo source="usage">RECOMMENDED</xs:appinfo>
                </xs:annotation>
            </xs:element>
            <xs:element id="CMM_10.00.00.00.00.00" name="StudyGroup" type="StudyGroupType"
                minOccurs="0" maxOccurs="unbounded">
                <xs:annotation>
                    <xs:appinfo source="CMMxpath">/CMM/StudyGroup</xs:appinfo>
                    <xs:appinfo source="ddi32xpath">null</xs:appinfo>
                    <xs:documentation xml:lang="en">Information on group(s) of
                        Studies.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element id="CMM_11.00.00.00.00.00" name="StudyDocumentationDescription"
                type="StudyDocumentationDescriptionType">
                <xs:annotation>
                    <xs:appinfo source="CMMxpath">/CMM/StudyDocumentationDescription</xs:appinfo>
                    <xs:appinfo source="ddi32xpath">null</xs:appinfo>
                    <xs:documentation xml:lang="en">Information on the study document
                        description.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>
    <!--ROOT  -->
    <!--*****************************************************************-->

    <xs:complexType name="StudySPURLType">
        <xs:simpleContent>
            <xs:extension base="xs:string">
                <xs:attribute id="CMM_01.01.10.05.01.00" name="typeOfUserID" type="xs:string"
                    use="required" fixed="URLServiceProvider">
                    <xs:annotation>
                        <xs:documentation xml:lang="en">Always
                            'URLServiceProvider'.</xs:documentation>
                        <xs:appinfo source="CMMxpath"
                            >/CMM/Study/BibliographicInformation/StudyVersion/StudySPURL/@typeOfUserID</xs:appinfo>
                        <xs:appinfo source="ddi32xpath"
                            >"ddi:DDIInstance/s:StudyUnit/r:UserID/@typeOfUserID"</xs:appinfo>
                    </xs:annotation>
                </xs:attribute>
            </xs:extension>
        </xs:simpleContent>
    </xs:complexType>
    <xs:complexType name="StudyType">
        <xs:sequence>
            <xs:element id="CMM_01.01.00.00.00.00" name="BibliographicInformation"
                type="BibliographicInformationType">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Holds study citation
                        information</xs:documentation>
                    <xs:appinfo source="CMMxpath">/CMM/Study/BibliographicInformation</xs:appinfo>
                    <xs:appinfo source="ddi32xpath">null</xs:appinfo>
                </xs:annotation>
            </xs:element>
            <xs:element id="CMM_01.02.00.00.00.00" name="ContentInformation"
                type="ContentInformationType" minOccurs="0" maxOccurs="1">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Information about Content of the
                        study</xs:documentation>
                    <xs:appinfo source="CMMxpath">/CMM/Study/ContentInformation</xs:appinfo>
                    <xs:appinfo source="ddi32xpath">null</xs:appinfo>
                    <xs:appinfo source="usage">RECOMMENDED</xs:appinfo>
                </xs:annotation>
            </xs:element>
            <xs:element id="CMM_01.03.00.00.00.00" name="MethodicalInformation"
                type="MethodicalInformationType" minOccurs="0" maxOccurs="1">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Information about methodology of the
                        study</xs:documentation>
                    <xs:appinfo source="CMMxpath">/CMM/Study/MethodicalInformation</xs:appinfo>
                    <xs:appinfo source="ddi32xpath">null</xs:appinfo>
                    <xs:appinfo source="usage">RECOMMENDED</xs:appinfo>
                </xs:annotation>
            </xs:element>
            <xs:element id="CMM_01.04.00.00.00.00" name="AccessInformation"
                type="AccessInformationType" minOccurs="1" maxOccurs="unbounded">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Legal or Access Information about the
                        study</xs:documentation>
                    <xs:appinfo source="CMMxpath">/CMM/Study/AccessInformation</xs:appinfo>
                    <xs:appinfo source="ddi32xpath">null</xs:appinfo>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="BibliographicInformationType">
        <xs:sequence>
            <xs:element id="CMM_01.01.01.00.00.00" name="StudyID" type="IdentifiableType_StudyID">
                <xs:annotation>
                    <xs:appinfo source="CMMxpath"
                        >/CMM/Study/BibliographicInformation/StudyID</xs:appinfo>
                    <xs:appinfo source="ddi32xpath">null</xs:appinfo>
                    <xs:documentation xml:lang="en">Identifier of the study according to DDI 3.2
                        structure. Either DDI URN or triple Agency, ID, Version need to be provided
                        as information.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element id="CMM_01.01.02.00.00.00" name="StudyNumber" type="StudyNumberType"
                minOccurs="1" maxOccurs="unbounded">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Unique archival number - if there is no unique
                        archival number available, a PID may be used alternatively (if a PID is used
                        as study number, the information for this PID should however still be
                        captured in the element CMM_01.01.10.04.00.00 Study PID)</xs:documentation>
                    <xs:appinfo source="CMMxpath"
                        >/CMM/Study/BibliographicInformation/StudyNumber</xs:appinfo>
                    <xs:appinfo source="ddi32xpath"
                        >/ddi:DDIInstance/s:StudyUnit/r:UserID</xs:appinfo>
                </xs:annotation>
            </xs:element>
            <xs:element id="CMM_01.01.03.00.00.00" name="StudyTitle"
                type="InternationalStringType_StudyTitle" minOccurs="1" maxOccurs="unbounded">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Study title</xs:documentation>
                    <xs:appinfo source="CMMxpath"
                        >/CMM/Study/BibliographicInformation/StudyTitle</xs:appinfo>
                    <xs:appinfo source="ddi32xpath"
                        >/ddi:DDIInstance/s:StudyUnit/r:Citation/r:Title/r:String</xs:appinfo>
                    <xs:appinfo/>
                </xs:annotation>
            </xs:element>
            <xs:element id="CMM_01.01.04.00.00.00" name="Subtitle"
                type="InternationalStringType_Subtitle" minOccurs="0" maxOccurs="unbounded">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Subtitle(s) of the study</xs:documentation>
                    <xs:appinfo source="CMMxpath"
                        >/CMM/Study/BibliographicInformation/Subtitle</xs:appinfo>
                    <xs:appinfo source="ddi32xpath"
                        >/ddi:DDIInstance/s:StudyUnit/r:Citation/r:SubTitle/r:String</xs:appinfo>
                </xs:annotation>
            </xs:element>
            <xs:element id="CMM_01.01.05.00.00.00" name="AlternativeTitle"
                type="InternationalStringType_AlternativeTitle" minOccurs="0" maxOccurs="unbounded">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Alternative title(s) of the
                        study</xs:documentation>
                    <xs:appinfo source="CMMxpath"
                        >/CMM/Study/BibliographicInformation/AlternativeTitle</xs:appinfo>
                    <xs:appinfo source="ddi32xpath"
                        >/ddi:DDIInstance/s:StudyUnit/r:Citation/r:AlternateTitle/r:String</xs:appinfo>
                </xs:annotation>
            </xs:element>
            <xs:element id="CMM_01.01.06.00.00.00" name="FundingInformation"
                type="FundingInformationType" minOccurs="0" maxOccurs="unbounded">
                <xs:annotation>
                    <xs:documentation>Provides information about the individual, agency and/or
                        grant(s) which funded the described entity. Lists a reference to the agency
                        or individual as described in a DDI Organization Scheme, the role of the
                        funder and the grant number(s).</xs:documentation>
                    <xs:documentation xml:lang="en">Funding Information</xs:documentation>
                    <xs:appinfo source="CMMxpath"
                        >/CMM/Study/BibliographicInformation/FundingInformation</xs:appinfo>
                    <xs:appinfo source="ddi32xpath"
                        >/ddi:DDIInstance/s:StudyUnit/r:FundingInformation</xs:appinfo>
                </xs:annotation>
            </xs:element>
            <xs:element id="CMM_01.01.07.00.00.00" name="PrincipalInvestigatorReference"
                minOccurs="0" maxOccurs="unbounded" type="PrincipalInvestigatorReferenceType">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Reference to individual/s and/or institution/s
                        that is/are principal investigators. Principal Investigator/s is/are the
                        main researchers involved in producing the data. NB - the metadata elements
                        concerning the principal investigator are the elements 1.3.1.1. and 1.3.1.2. </xs:documentation>
                    <xs:appinfo source="CMMxpath"
                        >/CMM/Study/BibliographicInformation/PrincipalInvestigatorReference</xs:appinfo>
                    <xs:appinfo source="ddi32xpath">null</xs:appinfo>
                </xs:annotation>

            </xs:element>
            <xs:element id="CMM_01.01.08.00.00.00" name="Publisher" minOccurs="1"
                maxOccurs="unbounded" type="InternationalStringType_Publisher">
                <xs:annotation>
                    <xs:documentation xml:lang="en">A name of the institution publishing the
                        metadata, i.e. the name of the actual CESSDA Service Provider providing the
                        metadata information. Only on study level.</xs:documentation>
                    <xs:appinfo source="CMMxpath"
                        >/CMM/Study/BibliographicInformation/Publisher</xs:appinfo>
                    <xs:appinfo source="ddi32xpath"
                        >/ddi:DDIInstance/s:StudyUnit/r:Citation/r:Publisher/r:PublisherName/r:String</xs:appinfo>
                </xs:annotation>
            </xs:element>
            <xs:element id="CMM_01.01.09.00.00.00" name="PublicationDate" type="BaseDateType">
                <xs:annotation>
                    <xs:documentation xml:lang="en">YDate (date-time combination
                        (YYYY-MM-DDTHH:MM:SS), date (YYYY-MM-DD), year-month (YYYY-MM), year (YYYY))
                        of publication (by publisher) of the study. Extract the year if only this is
                        needed (e.g. citation). This element refers to the date (ISO 8601) when the
                        data of the study was or will be made publicly available. If there is an
                        embargo on the data in effect, use the date when the embargo period ends. </xs:documentation>
                    <xs:appinfo source="CMMxpath"
                        >/CMM/Study/BibliographicInformation/PublicationDate</xs:appinfo>
                    <xs:appinfo source="ddi32xpath"
                        >/ddi:DDIInstance/s:StudyUnit/r:Citation/r:PublicationDate/r:SimpleDate</xs:appinfo>
                    <xs:appinfo source="usage">RECOMMENDED</xs:appinfo>
                </xs:annotation>
            </xs:element>
            <xs:element id="CMM_01.01.10.00.00.00" name="StudyVersion" type="StudyVersionType"
                minOccurs="0" maxOccurs="1">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Study Version Information</xs:documentation>
                    <xs:appinfo source="CMMxpath"
                        >/CMM/Study/BibliographicInformation/StudyVersion</xs:appinfo>
                    <xs:appinfo source="ddi32xpath">null</xs:appinfo>
                    <xs:appinfo source="usage">RECOMMENDED</xs:appinfo>
                </xs:annotation>
            </xs:element>
            <xs:element id="CMM_01.01.11.00.00.00" name="ContributorReference" minOccurs="0"
                maxOccurs="unbounded" type="ContributorReferenceType">
                <xs:annotation>
                    <xs:appinfo source="CMMxpath"
                        >/CMM/Study/BibliographicInformation/ContributorReference</xs:appinfo>
                    <xs:appinfo source="ddi32xpath">null</xs:appinfo>
                    <xs:documentation xml:lang="en">A contributor is a person or an institution that
                        is responsible for collecting, managing, distributing or otherwise
                        contributing to the development of the resource. It is any kind of
                        contributor to the study, that is NOT the principal investigator - e.g. data
                        collector, data manager, data depositor, project manager, sponsor
                        etc.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element id="CMM_01.01.12.00.00.00" name="ReferenceStudyToDocument" minOccurs="0"
                maxOccurs="unbounded" type="xs:string">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Reference of a study to a document, e.g
                        questionnaire.</xs:documentation>
                    <xs:appinfo source="CMMxpath"
                        >/CMM/Study/BibliographicInformation/ReferenceToDocument</xs:appinfo>
                    <xs:appinfo source="ddi32xpath"
                        >/ddi:DDIInstance/g:Group/g:Subgroup/s:StudyUnit/r:OtherMaterial</xs:appinfo>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="ContentInformationType">
        <xs:sequence>
            <xs:element id="CMM_01.02.01.00.00.00" name="Abstract"
                type="InternationalStringType_Abstract" minOccurs="1" maxOccurs="unbounded">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Abstract that describes the content(s) of the
                        study [remark: information for CDC - content must be provided at least in
                        English, if study is supposed to show up in the CDC - other additional
                        languages are welcome]</xs:documentation>
                    <xs:appinfo source="CMMxpath"
                        >/CMM/Study/ContentInformation/Abstract</xs:appinfo>
                    <xs:appinfo source="ddi32xpath"
                        >/ddi:DDIInstance/s:StudyUnit/r:Abstract/r:Content</xs:appinfo>
                </xs:annotation>
            </xs:element>
            <xs:element id="CMM_01.02.02.00.00.00" name="StudyTopic"
                type="InternationalReferencedVocabType_StudyTopic" minOccurs="0"
                maxOccurs="unbounded">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Code value or decriptive term of the CV "CESSDA
                        Topic Classification" or other.</xs:documentation>
                    <xs:appinfo source="CMMxpath"
                        >/CMM/Study/ContentInformation/StudyTopic</xs:appinfo>
                    <xs:appinfo source="ddi32xpath"
                        >/ddi:DDIInstance/s:StudyUnit/r:Coverage/r:TopicalCoverage/r:Subject</xs:appinfo>
                    <xs:appinfo source="usage">RECOMMENDED</xs:appinfo>
                </xs:annotation>
            </xs:element>
            <xs:element id="CMM_01.02.03.00.00.00" name="Keyword"
                type="InternationalReferencedVocabType_Keyword" minOccurs="0" maxOccurs="unbounded">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Value of the code or descriptive term. Use
                        descriptive term for ELSST. For other keywords it is optional to use the
                        descriptive term or the value code. Keywords from thesauri (preferrably
                        ELSST) or CVs, that specify the content of the study" </xs:documentation>
                    <xs:appinfo source="CMMxpath">/CMM/Study/ContentInformation/Keyword</xs:appinfo>
                    <xs:appinfo source="ddi32xpath"
                        >/ddi:DDIInstance/s:StudyUnit/r:Coverage/r:TopicalCoverage/r:Keyword</xs:appinfo>
                    <xs:appinfo source="usage">RECOMMENDED</xs:appinfo>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="MethodicalInformationType">
        <xs:sequence>
            <xs:element id="CMM_01.03.01.00.00.00 " name="TimeMethod" type="TimeMethodType"
                minOccurs="1" maxOccurs="unbounded">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Describes the time dimension of the data
                        collection.</xs:documentation>
                    <xs:appinfo source="CMMxpath"
                        >/CMM/Study/MethodicalInformation/TimeMethod</xs:appinfo>
                    <xs:appinfo source="ddi32xpath">null</xs:appinfo>
                </xs:annotation>
            </xs:element>
            <xs:element id="CMM_01.03.02.00.00.00" name="StudyAreaCountry"
                type="ReferencedVocabType_StudyAreaCountry" minOccurs="0" maxOccurs="unbounded">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Country in which the study took place. use ISO
                        3166-1 alpha 2. If that is not possible, use another ISO Code and state in
                        the attribute which ISO-Code you are using. CDC recommends using both the
                        free-text element and the code if the country is in the ISO 3166-1 alpha 2
                        list. If not in the code list, then use the free-text element
                        only.</xs:documentation>
                    <xs:appinfo source="CMMxpath"
                        >/CMM/Study/MethodicalInformation/StudyAreaCountry</xs:appinfo>
                    <xs:appinfo source="ddi32xpath"
                        >/ddi:DDIInstance/s:StudyUnit/r:Coverage/r:SpatialCoverage/r:Country_2</xs:appinfo>
                    <xs:appinfo source="usage">RECOMMENDED</xs:appinfo>
                </xs:annotation>
            </xs:element>
            <xs:element id="CMM_01.03.03.00.00.00 " name="StudyAreaCountryText"
                type="InternationalStringType_StudyAreaCountryText" minOccurs="0"
                maxOccurs="unbounded">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Country in which the study took place
                        (freetext)</xs:documentation>
                    <xs:appinfo source="CMMxpath"
                        >/CMM/Study/MethodicalInformation/StudyAreaCountryText</xs:appinfo>
                    <xs:appinfo source="ddi32xpath"
                        >/ddi:DDIInstance/s:StudyUnit/r:Coverage/r:SpatialCoverage/r:Description/r:Content</xs:appinfo>
                    <xs:appinfo source="usage">RECOMMENDED</xs:appinfo>
                </xs:annotation>
            </xs:element>
            <xs:element id="CMM_01.03.04.00.00.00 " name="Universe"
                type="InternationalStringType_Universe" minOccurs="0" maxOccurs="unbounded">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Description of the population of the study
                        (freetext)</xs:documentation>
                    <xs:appinfo source="CMMxpath"
                        >/CMM/Study/MethodicalInformation/Universe</xs:appinfo>
                    <xs:appinfo source="ddi32xpath"
                        >/ddi:DDIInstance/s:StudyUnit/c:ConceptualComponent/c:UniverseScheme/c:Universe/r:Description/r:Content</xs:appinfo>
                    <xs:appinfo source="usage">RECOMMENDED</xs:appinfo>
                </xs:annotation>
            </xs:element>
            <xs:element id="CMM_01.03.05.00.00.00 " name="UnitOfAnalysis" type="UnitofAnalysisType"
                minOccurs="1" maxOccurs="unbounded">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Describes the entity being analyzed in the study
                        or in the variable. The unit sampled - type of units in the dataset, e.g.
                        individual, organization</xs:documentation>
                    <xs:appinfo source="CMMxpath"
                        >/CMM/Study/MethodicalInformation/UnitOfAnalysis</xs:appinfo>
                    <xs:appinfo source="ddi32xpath">null</xs:appinfo>
                </xs:annotation>
            </xs:element>
            <xs:element id="CMM_01.03.06.00.00.00" name="SamplingInformation"
                type="SamplingInformationType" minOccurs="0" maxOccurs="unbounded">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Information about the sampling methodology used
                        in the study</xs:documentation>
                    <xs:appinfo source="CMMxpath"
                        >/CMM/Study/MethodicalInformation/SamplingInformation</xs:appinfo>
                    <xs:appinfo source="ddi32xpath">null</xs:appinfo>
                    <xs:appinfo source="usage">RECOMMENDED</xs:appinfo>
                </xs:annotation>
            </xs:element>
