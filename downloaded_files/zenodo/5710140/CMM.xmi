								<UML:AssociationEnd visibility="public" multiplicity="1..*" name="StudySPURL" aggregation="none" isOrdered="false" targetScope="instance" changeable="none" isNavigable="true" type="EAID_B962309A_F31E_4b81_A0BD_68DFA593E668">
									<UML:ModelElement.taggedValue>
										<UML:TaggedValue tag="description" value="A URL or URN (a reference to a web resource that&#xA;                        specifies its location) linking to the study on the SP website. This is the&#xA;                        document the metadata refers to, i.e. URL of the study description at the SP&#xA;                        website. CDC and EQB provide a link from a study description to the study&#xA;                        description on SP website. [Element not visible in the UI, only needed for&#xA;                        the link]."/>
										<UML:TaggedValue tag="containment" value="Unspecified"/>
										<UML:TaggedValue tag="deststyle" value="Union=0;Derived=0;AllowDuplicates=0;Owned=0;Navigable=Navigable;"/>
