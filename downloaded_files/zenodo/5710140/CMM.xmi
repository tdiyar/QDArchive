						<UML:Class name="IdentifiableType_ReferencedCodeList" xmi.id="EAID_FB69693B_3534_4872_93C7_9C4B0FAF2C57" visibility="public" namespace="EAPK_33C071FF_5C06_4c87_9E13_2B11DB0D39B0" isRoot="false" isLeaf="false" isAbstract="false" isActive="false">
